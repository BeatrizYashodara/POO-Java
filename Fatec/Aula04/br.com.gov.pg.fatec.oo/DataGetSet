package br.gov.sp.fatec.pg.oo;


public class Data {
    private int dia;
    private int mês;
    private int ano;
    // default de java eh friendly 

    public void setDia(int novoDia){
        if(novoDia < 1) dia = 1;
        else if (novoDia > 31) dia = 31;
        else dia = novoDia;
    }

    public int getDia(){
        return dia;
    }

}
